{
  "name": "google-scraper",
  "version": "1.0.0",
  "description": "Google Scholar Publications Scraper",
  "main": "index.js",
  "scripts": {
    "client": "cd client && npm start",
    "server": "cd server && npm run dev",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "install-all": "npm install && cd client && npm install && cd ../server && npm install"
  },
  "keywords": [
    "google-scholar",
    "publications",
    "react",
    "nodejs",
    "scraping"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
