{
  "name": "google-scraper",
  "version": "1.0.0",
  "description": "Google Scholar Publications Scraper",
  "main": "index.js",
  "scripts": {
    "client": "cd client && npm start",
    "server": "cd server && npm run dev",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "test": "jest",
    "test:integration": "newman run server/tests/postman/collections/registration-api.json -e server/tests/postman/environments/development.postman_environment.json",
    "test:all": "npm run test:unit && npm run test:integration",
    "install-all": "npm install && cd client && npm install && cd ../server && npm install"
  },
  "keywords": [
    "google-scholar",
    "publications",
    "react",
    "nodejs",
    "scraping"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.2",
    "jest": "^30.4.2",
    "newman": "^6.2.2"
  }
}
