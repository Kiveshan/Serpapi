{
    "info": {
        "name": "Registration API",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "item": [
        {
            "name": "1. User Registration",
            "item": [
                {
                    "name": "POST /auth/register - Success Case",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "// Status code validation",
                                    "pm.test(\"Status code is 201\", function () {",
                                    "    pm.response.to.have.status(201);",
                                    "});",
                                    "",
                                    "// Response structure validation",
                                    "pm.test(\"Response has required fields\", function () {",
                                    "    const jsonData = pm.response.json();",
                                    "    pm.expect(jsonData).to.have.property('message');",
                                    "    pm.expect(jsonData).to.have.property('user');",
                                    "    pm.expect(jsonData).to.have.property('token');",
                                    "});",
                                    "",
                                    "// User data validation",
                                    "pm.test(\"User data is correct\", function () {",
                                    "    const jsonData = pm.response.json();",
                                    "    pm.expect(jsonData.user.fullname).to.eql(pm.environment.get(\"testFullName\"));",
                                    "    pm.expect(jsonData.user.institutionemail).to.eql(pm.environment.get(\"testEmail\"));",
                                    "    pm.expect(jsonData.user.enabled).to.eql(false);",
                                    "    pm.expect(jsonData.user.status).to.eql('pending');",
                                    "});",
                                    "",
                                    "// Token validation",
                                    "pm.test(\"Token is valid JWT\", function () {",
                                    "    const jsonData = pm.response.json();",
                                    "    const token = jsonData.token;",
                                    "    const parts = token.split('.');",
                                    "    pm.expect(parts).to.have.lengthOf(3);",
                                    "});",
                                    "",
                                    "// Set environment variables",
                                    "if (pm.response.code === 201) {",
                                    "    const jsonData = pm.response.json();",
                                    "    pm.environment.set(\"userId\", jsonData.user.userid);",
                                    "    pm.environment.set(\"authToken\", jsonData.token);",
                                    "}"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [],
                        "body": {
                            "mode": "formdata",
                            "formdata": [
                                {
                                    "key": "fullname",
                                    "value": "{{testFullName}}",
                                    "type": "text"
                                },
                                {
                                    "key": "institutionemail",
                                    "value": "{{testEmail}}",
                                    "type": "text"
                                },
                                {
                                    "key": "password",
                                    "value": "{{testPassword}}",
                                    "type": "text"
                                },
                                {
                                    "key": "institutionid",
                                    "value": "1",
                                    "type": "text"
                                },
                                {
                                    "key": "roleid",
                                    "value": "2",
                                    "type": "text"
                                },
                                {
                                    "key": "certificate",
                                    "type": "file",
                                    "src": "{{testCertificatePath}}"
                                }
                            ]
                        },
                        "url": {
                            "raw": "{{baseUrl}}/auth/register",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "auth",
                                "register"
                            ]
                        }
                    }
                },
                {
                    "name": "POST /auth/register - Missing Required Fields",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test(\"Status code is 400\", function () { pm.response.to.have.status(400); });",
                                    "pm.test(\"Error message is present\", function () {",
                                    "    const jsonData = pm.response.json();",
                                    "    pm.expect(jsonData).to.have.property('error');",
                                    "});"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [],
                        "body": {
                            "mode": "formdata",
                            "formdata": [
                                {
                                    "key": "fullname",
                                    "value": "Test User",
                                    "type": "text"
                                }
                            ]
                        },
                        "url": {
                            "raw": "{{baseUrl}}/auth/register",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "auth",
                                "register"
                            ]
                        }
                    }
                },
                {
                    "name": "POST /auth/register - Duplicate Email",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test(\"Status code is 409\", function () { pm.response.to.have.status(409); });",
                                    "pm.test(\"Error message indicates duplicate email\", function () {",
                                    "    const jsonData = pm.response.json();",
                                    "    pm.expect(jsonData.error).to.include('already exists');",
                                    "});"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [],
                        "body": {
                            "mode": "formdata",
                            "formdata": [
                                {
                                    "key": "fullname",
                                    "value": "Duplicate User",
                                    "type": "text"
                                },
                                {
                                    "key": "institutionemail",
                                    "value": "{{testEmail}}",
                                    "type": "text"
                                },
                                {
                                    "key": "password",
                                    "value": "{{testPassword}}",
                                    "type": "text"
                                },
                                {
                                    "key": "certificate",
                                    "type": "file",
                                    "src": "{{testCertificatePath}}"
                                }
                            ]
                        },
                        "url": {
                            "raw": "{{baseUrl}}/auth/register",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "auth",
                                "register"
                            ]
                        }
                    }
                }
            ]
        },
        {
            "name": "2. Authentication",
            "item": [
                {
                    "name": "POST /auth/login - Valid Credentials",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test(\"Status code is 200\", function () { pm.response.to.have.status(200); });",
                                    "pm.test(\"Response has user and token\", function () {",
                                    "    const jsonData = pm.response.json();",
                                    "    pm.expect(jsonData).to.have.property('user');",
                                    "    pm.expect(jsonData).to.have.property('token');",
                                    "});",
                                    "if (pm.response.code === 200) {",
                                    "    const jsonData = pm.response.json();",
                                    "    pm.environment.set(\"authToken\", jsonData.token);",
                                    "}"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"institutionemail\": \"{{approvedUserEmail}}\",\n  \"password\": \"{{approvedUserPassword}}\"\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": {
                            "raw": "{{baseUrl}}/auth/login",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "auth",
                                "login"
                            ]
                        }
                    }
                }
            ]
        },
        {
            "name": "3. Supporting Data",
            "item": [
                {
                    "name": "GET /auth/institutions",
                    "request": {
                        "method": "GET",
                        "url": {
                            "raw": "{{baseUrl}}/auth/institutions",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "auth",
                                "institutions"
                            ]
                        }
                    }
                },
                {
                    "name": "GET /auth/roles",
                    "request": {
                        "method": "GET",
                        "url": {
                            "raw": "{{baseUrl}}/auth/roles",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "auth",
                                "roles"
                            ]
                        }
                    }
                }
            ]
        }
    ]
}